# Streamlit Cloud Secrets Configuration
# Copy this to Streamlit Cloud: Settings → Secrets

# Application Settings
APP_NAME = "Adobe Influencer Intelligence System"
ENVIRONMENT = "production"
USE_MOCK_DATA = "true"
LOG_LEVEL = "INFO"

# Database (use in-memory for Streamlit Cloud free tier)
DATABASE_URL = "sqlite:///:memory:"
DUCKDB_PATH = ":memory:"

# API Keys (Replace with your actual keys)
YOUTUBE_API_KEY = "your_youtube_api_key_here"
APIFY_TOKEN = "your_apify_token_here"

# Media Pipeline Settings (disabled by default for demo)
ENABLE_MEDIA_PIPELINE = "false"
WHISPER_MODEL = "base"
MAX_VIDEOS_PER_CREATOR = "5"
